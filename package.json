{
  "name": "flow-kanban",
  "version": "0.1.0",
  "description": "Personal Kanban app for UX designers",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev:desktop": "npm run dev --workspace=packages/desktop",
    "dev:mobile": "npm run dev --workspace=packages/mobile",
    "build:desktop": "npm run build --workspace=packages/desktop",
    "build:mobile": "npm run build --workspace=packages/mobile",
    "test": "npm run test --workspaces",
    "lint": "npm run lint --workspaces"
  },
  "keywords": [
    "kanban",
    "productivity",
    "personal",
    "task-management"
  ],
  "author": "Your Name",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.11.0"
  }
}
