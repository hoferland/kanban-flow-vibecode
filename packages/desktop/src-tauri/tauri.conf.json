{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Flow",
  "version": "0.1.0",
  "identifier": "com.flow.kanban",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Flow - Personal Kanban",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "shortDescription": "Personal Kanban Board",
    "longDescription": "A personal Kanban board for UX designers managing multiple teams"
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/hoferland/first-repo/releases/latest/download/latest.json"
      ],
      "dialog": false,
      "pubkey": ""
    }
  }
}
